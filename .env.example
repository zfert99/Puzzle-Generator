# Phase 4 environment variables. Copy to `.env.local` (git-ignored) and fill in.
# NEVER commit real secrets — only this template is tracked.

# --- Database (4.1) ---
# Neon Postgres connection string, installed via the Vercel Marketplace integration.
# Use the POOLED connection string for the app (Neon HTTP driver). drizzle-kit `migrate`
# reads this same var. Format:
#   postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=

# Optional: direct (non-pgbouncer) connection used by drizzle-kit for migrations/DDL.
# Neon exposes this as the "unpooled" string (no `-pooler` in the host). If unset,
# migrations fall back to DATABASE_URL.
DATABASE_URL_UNPOOLED=

# --- Daily puzzle cron (4.2) ---
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`; the route
# compares it in constant time and 401s anything else. Set the same value in the Vercel
# project env so Vercel attaches it automatically. Generate with:
#   openssl rand -base64 32
CRON_SECRET=

# --- Auth (4.3) ---
# better-auth server secret — sign/encrypt sessions. 32+ chars. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the app (drives passkey rpID/origin and OAuth callbacks).
BETTER_AUTH_URL=http://localhost:3000
# Google OAuth (optional bootstrap). If unset, email/password + passkeys still work.
# Authorized redirect URI to register with Google: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Rate limiting ---
# Upstash Redis REST credentials — shares the auth rate limiter's counters across Vercel's
# separate serverless instances. Optional: unset falls back to better-auth's in-memory
# default (fine for local dev). If provisioned via Vercel's "Upstash for Redis" marketplace
# integration, it injects these under KV_REST_API_URL/KV_REST_API_TOKEN instead — both
# names work, no renaming needed (see rate-limit-storage.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Logging (existing) ---
# LOG_LEVEL=info
